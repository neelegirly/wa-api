{
  "name": "@neelify/wa-api",
  "version": "1.7.1",
  "description": "Conservative multi-session WhatsApp wrapper for @neelify/baileys with QR and pairing support.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neelify/wa-api.git"
  },
  "homepage": "https://github.com/neelify/wa-api#readme",
  "bugs": {
    "url": "https://github.com/neelify/wa-api/issues"
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "readme.md"
  ],
  "scripts": {
    "build": "node -e \"console.log('Packaged dist artifacts are already included.')\"",
    "start": "node -e \"require('./dist/index.js'); console.log('wa-api loaded')\"",
    "test": "node -e \"require('./dist/index.js'); console.log('wa-api smoke test passed')\"",
    "run-script": "node -e \"require('./dist/index.js')\""
  },
  "keywords": [
    "whatsapp",
    "neelify",
    "baileys",
    "multi-session",
    "qr",
    "pairing"
  ],
  "author": "Neele",
  "license": "ISC",
  "dependencies": {
    "jest": "^29.0.0",
    "@adiwajshing/keyed-db": "^0.2.4",
    "@hapi/boom": "^10.0.1",
    "@neelify/baileys": "^2.2.0",
    "mime": "^3.0.0",
    "pino": "^8.11.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/mime": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
